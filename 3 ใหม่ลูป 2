<?php
// กำหนดตัวแปรเริ่มต้นที่เลขคู่ตัวแรก คือ 2
$number = 2; 

echo "--- แสดงเลขคู่ตั้งแต่ 2 ถึง 20 ---<br>";

do {
    // แสดงตัวเลขปัจจุบัน
    echo $number . " ";
    
    // เพิ่มค่าทีละ 2 เพื่อให้เป็นเลขคู่ถัดไป (2 -> 4 -> 6 -> ...)
    $number += 2; 
    
} while ($number <= 20); // เช็คเงื่อนไข: ทำซ้ำตราบใดที่ $number ยังไม่เกิน 20
?>
