#include <stdio.h>

int main() {
    int number = 2; // เริ่มต้นที่เลขคู่ตัวแรกคือ 2

    printf("เลขคู่ตั้งแต่ 2 ถึง 20 คือ:\n");
    
    do {
        printf("%d ", number);
        number += 2; // เพิ่มทีละ 2 เพื่อให้เป็นเลขคู่ถัดไป
    } while (number <= 20); // ทำซ้ำตราบใดที่ต้วเลขยังไม่เกิน 20

    return 0;
}
