# ตัวอย่างภาษา Python (สมมติรายชื่อนักเรียนห้อง 6/8)
students_6_8 = ["บึงพิพัฒน์", "สมหญิง", "สมศักดิ์", "สมศรี", "สมปอง"]

print("--- รายชื่อนักเรียนห้อง 6/8 (for loop) ---")

# ลูปโดยเริ่มจาก index 0 (เลขที่ 1) ไปจนถึงคนสุดท้าย
for i in range(len(students_6_8)):
    student_number = i + 1  # เลขที่ = index + 1
    print(f"เลขที่ {student_number}: {students_6_8[i]}")
