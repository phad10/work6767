<?php
// กำหนดค่าเริ่มต้นของเซลเซียส (C) เริ่มจาก 0
$celsius = 0; 

echo "--- ตารางแปลงค่า องศา C เป็น ฟาเรนไฮต์ (F) ---<br>";

// ใช้ while loop วนลูปจนกว่าค่า celsius จะมากกว่า 10
while ($celsius <= 10) {
    // สูตรคำนวณ: ฟาเรนไฮต์ = (เซลเซียส * 1.8) + 32
    $fahrenheit = ($celsius * 1.8) + 32;
    
    // แสดงผลลัพธ์
    echo "เซลเซียส: $celsius °C | ฟาเรนไฮต์: $fahrenheit °F<br>";
    
    // เพิ่มค่าเซลเซียสทีละ 1 ในแต่ละรอบ
    $celsius++; 
}
?>
